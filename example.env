# .env file: Environment variables for Privateerr configuration.
#

#
# Name of the project which adds namespace for all services and volumes.
#
COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT_NAME:-privateerr}

#
# Default healthcheck timing settings.
#
DEFAULT_HEALTHCHECK_INTERVAL="${DEFAULT_HEALTHCHECK_INTERVAL:-30s}"
DEFAULT_HEALTHCHECK_TIMEOUT="${DEFAULT_HEALTHCHECK_TIMEOUT:-10s}"
DEFAULT_HEALTHCHECK_START_PERIOD="${DEFAULT_HEALTHCHECK_START_PERIOD:-10s}"
DEFAULT_HEALTHCHECK_RETRIES="${DEFAULT_HEALTHCHECK_RETRIES:-3}"

#
# Privateerr service tag, build, and volume variables.
#
PRIVATEERR_TAG="${PRIVATEERR_TAG:-latest}"
ALPINE_TAG="${ALPINE_TAG:-3.24@sha256:28bd5fe8b56d1bd048e5babf5b10710ebe0bae67db86916198a6eec434943f8b}"
PIA_BIN_HOME="${PIA_BIN_HOME:-/pia}"
PRIVATEERR_BIN_HOME="${PRIVATEERR_BIN_HOME:-/privateerr}"
IMAGE_CREATED="${IMAGE_CREATED:-unknown}"
IMAGE_REVISION="${IMAGE_REVISION:-unknown}"
PRIVATEERR_CONFIG_PATH="${PRIVATEERR_CONFIG_PATH:-./config/privateerr}"
PRIVATEERR_GLUETUN_CONFIG_PATH="${PRIVATEERR_GLUETUN_CONFIG_PATH:-./config/gluetun}"

# Privateerr service PIA manual connection environment variables.
PIA_VPN_PROTOCOL="${PIA_VPN_PROTOCOL:-wireguard}"
PIA_DISABLE_IPV6="${PIA_DISABLE_IPV6:-yes}"
PIA_DIP_TOKEN="${PIA_DIP_TOKEN:-no}"
PIA_AUTOCONNECT="${PIA_AUTOCONNECT:-true}"
PIA_CONF_PATH="${PIA_CONF_PATH:-/gluetun/wireguard/wg0.conf}"
PIA_CONNECT="${PIA_CONNECT:-false}"
PIA_PF="${PIA_PF:-true}"
PIA_DNS="${PIA_DNS:-true}"
PIA_WG_SERVER_NAME="${PIA_WG_SERVER_NAME:-}"
PIA_USER="${PIA_USER:-p1234567}"
PIA_PASS="${PIA_PASS:-shiverMeTimbers123}"

# Privateerr service Privateerr environment variables.
PRIVATEERR_METADATA_PATH="${PRIVATEERR_METADATA_PATH:-/gluetun/wireguard/privateerr.env}"
PRIVATEERR_HEALTHCHECK_MARKER="${PRIVATEERR_HEALTHCHECK_MARKER:-/healthcheck/privateerr.ready}"
PRIVATEERR_KEEPALIVE="${PRIVATEERR_KEEPALIVE:-true}"
PRIVATEERR_LOG_PATH="${PRIVATEERR_LOG_PATH:-/privateerr-config/logs/privateerr.log}"

#
# Gluetun service tag, wrapper, volume, and environment variables.
#
GLUETUN_TAG="${GLUETUN_TAG:-latest}"
GLUETUN_CONFIG_PATH="${GLUETUN_CONFIG_PATH:-./config/gluetun}"
GLUETUN_WRAPPER_SCRIPT_PATH="${GLUETUN_WRAPPER_SCRIPT_PATH:-./config/gluetun/scripts/gluetun-entrypoint-wrapper.sh}"
GLUETUN_ENTRYPOINT_WRAPPER="${GLUETUN_ENTRYPOINT_WRAPPER:-/privateerr/gluetun-entrypoint-wrapper.sh}"
GLUETUN_VPN_SERVICE_PROVIDER="${GLUETUN_VPN_SERVICE_PROVIDER:-custom}"
GLUETUN_VPN_TYPE="${GLUETUN_VPN_TYPE:-wireguard}"
GLUETUN_VPN_PORT_FORWARDING="${GLUETUN_VPN_PORT_FORWARDING:-on}"
GLUETUN_VPN_PORT_FORWARDING_PROVIDER="${GLUETUN_VPN_PORT_FORWARDING_PROVIDER:-private internet access}"
GLUETUN_HEALTH_TARGET_ADDRESSES="${GLUETUN_HEALTH_TARGET_ADDRESSES:-cloudflare.com:443,github.com:443}"
GLUETUN_HEALTH_ICMP_TARGET_IPS="${GLUETUN_HEALTH_ICMP_TARGET_IPS:-1.1.1.1,8.8.8.8}"
GLUETUN_HEALTH_RESTART_VPN="${GLUETUN_HEALTH_RESTART_VPN:-on}"
GLUETUN_DEFAULT_ENTRYPOINT="${GLUETUN_DEFAULT_ENTRYPOINT:-/gluetun-entrypoint}"
PRIVATEERR_GLUETUN_METADATA_WAIT_SECONDS="${PRIVATEERR_GLUETUN_METADATA_WAIT_SECONDS:-120}"

#
# Buccaneerr service tag, build, volume, and environment variables.
#
BUCCANEERR_TAG="${BUCCANEERR_TAG:-latest}"
BUCCANEERR_BIN_HOME="${BUCCANEERR_BIN_HOME:-/buccaneerr}"
BUCCANEERR_CONFIG_HOME="${BUCCANEERR_CONFIG_HOME:-./config/buccaneerr}"
BUCCANEERR_CONFIG_PATH_HOST="${BUCCANEERR_CONFIG_PATH_HOST:-./config/gluetun/wireguard}"
BUCCANEERR_GLUETUN_PATH_HOST="${BUCCANEERR_GLUETUN_PATH_HOST:-./config/gluetun}"
BUCCANEERR_CONFIG_PATH="${BUCCANEERR_CONFIG_PATH:-/config}"
BUCCANEERR_GLUETUN_PATH="${BUCCANEERR_GLUETUN_PATH:-/gluetun}"
BUCCANEERR_HEALTH_URL="${BUCCANEERR_HEALTH_URL:-http://127.0.0.1:9999}"
BUCCANEERR_REQUIRE_PORT_FORWARD="${BUCCANEERR_REQUIRE_PORT_FORWARD:-true}"
BUCCANEERR_LOG_PATH="${BUCCANEERR_LOG_PATH:-/buccaneerr-config/logs/buccaneerr.log}"
